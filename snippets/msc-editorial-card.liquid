{% comment %}Accepts: title, dek, label, link, size, meta{% endcomment %}
<article class="msc-editorial-card msc-editorial-card--{{ size | default: 'standard' }} msc-glass-card">
  <a class="msc-editorial-card__link" href="{{ link | default: '#MainContent' }}">
    <span class="msc-editorial-card__label">{{ label | default: 'Editorial' | escape }}</span>
    <h3>{{ title | escape }}</h3>
    {%- if dek != blank -%}<p>{{ dek | escape }}</p>{%- endif -%}
    {%- if meta != blank -%}<span class="msc-editorial-card__meta">{{ meta | escape }}</span>{%- endif -%}
  </a>
</article>
