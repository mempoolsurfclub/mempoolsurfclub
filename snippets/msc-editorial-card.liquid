{% comment %}Accepts: article, label, size{% endcomment %}
{%- assign card_size = 'standard' -%}
{%- if size == true or size == 'lead' -%}{%- assign card_size = 'lead' -%}{%- endif -%}
{%- assign summary = article.excerpt | default: article.excerpt_or_content | strip_html | truncatewords: 26 -%}
{%- assign image_alt = article.image.alt | default: article.title -%}
<article class="msc-editorial-card msc-editorial-card--{{ card_size }} msc-glass-card">
  <a class="msc-editorial-card__link" href="{{ article.url }}" aria-label="Read {{ article.title | escape }}">
    {%- if article.image != blank -%}
      <div class="msc-editorial-card__media">{{ article.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: image_alt }}</div>
    {%- else -%}
      <div class="msc-editorial-card__archive" aria-hidden="true"><span>MSC</span><i></i><i></i><i></i></div>
    {%- endif -%}
    <span class="msc-editorial-card__label">{{ label | default: 'Editorial' | escape }}</span>
    <h3>{{ article.title | escape }}</h3>
    {%- if summary != blank -%}<p>{{ summary | escape }}</p>{%- endif -%}
    <time class="msc-editorial-card__meta" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%b %-d, %Y' }}</time>
  </a>
</article>
