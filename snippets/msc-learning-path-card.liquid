{% comment %}
  Renders an MSC learning path card.
  Accepts: title, description, link, marker, recommended, recommended_label, action_label
{% endcomment %}
{%- assign card_marker = marker | default: 'Surface route' -%}
{%- assign normalized_marker = card_marker | handleize -%}
{%- assign depth_class = 'surface' -%}
{%- if normalized_marker contains 'harbor' -%}
  {%- assign depth_class = 'harbor' -%}
{%- elsif normalized_marker contains 'current' -%}
  {%- assign depth_class = 'current' -%}
{%- elsif normalized_marker contains 'deep' -%}
  {%- assign depth_class = 'deep' -%}
{%- elsif normalized_marker contains 'open-ocean' -%}
  {%- assign depth_class = 'open-ocean' -%}
{%- endif -%}
{%- assign card_classes = 'msc-learn-path-card msc-glass-card msc-learn-path-card--' | append: depth_class -%}
{%- if recommended -%}{%- assign card_classes = card_classes | append: ' msc-learn-path-card--recommended' -%}{%- endif -%}
{%- assign resolved_link = link -%}
{%- if resolved_link == blank and planned_handle != blank -%}
  {%- assign planned_page = pages[planned_handle] -%}
  {%- if planned_page -%}{%- assign resolved_link = planned_page.url -%}{%- endif -%}
{%- endif -%}
{%- if resolved_link != blank -%}
  <a class="{{ card_classes }} msc-learn-path-card--linked" href="{{ resolved_link }}">
{%- else -%}
  <article class="{{ card_classes }} msc-learn-path-card--static">
{%- endif -%}
  <div class="msc-learn-path-card__badge-row">
    {%- if recommended -%}
      <span class="msc-learn-path-card__badge">{{ recommended_label | default: 'Recommended start' | escape }}</span>
    {%- endif -%}
  </div>
  <div class="msc-learn-path-card__body">
    <p class="msc-learn-path-card__route">{{ card_marker | escape }}</p>
    <h3>{{ title | escape }}</h3>
    <p>{{ description | escape }}</p>
  </div>
  <span class="msc-card-arrow">{{ action_label | default: 'Enter route' | escape }} <span aria-hidden="true">→</span></span>
{%- if resolved_link != blank -%}
  </a>
{%- else -%}
  </article>
{%- endif -%}
