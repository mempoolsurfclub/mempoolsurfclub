{% comment %}
  Renders an MSC learning path card.
  Accepts: index, title, description, link, marker
{% endcomment %}
{%- assign card_index = index | default: '01' -%}
{%- assign card_marker = marker | default: 'Surface route' -%}
{%- if link != blank -%}<a class="msc-learn-path-card msc-glass-card" href="{{ link }}">{%- else -%}<article class="msc-learn-path-card msc-glass-card">{%- endif -%}
  <span class="msc-learn-path-card__index">{{ card_index | escape }}</span>
  <span class="msc-learn-path-card__marker" aria-hidden="true"></span>
  <div>
    <p class="msc-learn-path-card__route">{{ card_marker | escape }}</p>
    <h3>{{ title | escape }}</h3>
    <p>{{ description | escape }}</p>
  </div>
  <span class="msc-card-arrow">Enter →</span>
{%- if link != blank -%}</a>{%- else -%}</article>{%- endif -%}
