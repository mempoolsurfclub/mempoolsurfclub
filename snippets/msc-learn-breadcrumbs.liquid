<nav class="msc-learn-breadcrumbs" aria-label="Learn breadcrumbs">
  <ol>
    <li>{% if learn_page %}<a href="{{ learn_page.url }}">Learn</a>{% else %}<span>Learn</span>{% endif %}</li>
    {% if category_label != blank %}<li>{% if category_page %}<a href="{{ category_page.url }}">{{ category_label | escape }}</a>{% else %}<span>{{ category_label | escape }}</span>{% endif %}</li>{% endif %}
    {% if subcategory_label != blank %}<li><span>{{ subcategory_label | escape }}</span></li>{% endif %}
    <li aria-current="page"><span>{{ current_label | default: page.title | escape }}</span></li>
  </ol>
</nav>
