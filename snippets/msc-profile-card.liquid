{% comment %}Accepts: article, tag{% endcomment %}
{%- assign summary = article.excerpt | default: article.excerpt_or_content | strip_html | truncatewords: 22 -%}
{%- assign image_alt = article.image.alt | default: article.title -%}
<article class="msc-profile-card msc-glass-card">
  <a class="msc-profile-card__link" href="{{ article.url }}" aria-label="Read {{ article.title | escape }}">
    {%- if article.image != blank -%}
      <div class="msc-profile-card__media">{{ article.image | image_url: width: 720 | image_tag: loading: 'lazy', alt: image_alt }}</div>
    {%- else -%}
      <div class="msc-profile-card__orb" aria-hidden="true"></div>
    {%- endif -%}
    <span class="msc-profile-card__tag">{{ tag | default: 'Profile' | escape }}</span>
    <h3>{{ article.title | escape }}</h3>
    <time class="msc-profile-card__role" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%b %-d, %Y' }}</time>
    {%- if summary != blank -%}<p class="msc-profile-card__description">{{ summary | escape }}</p>{%- endif -%}
  </a>
</article>
