{% comment %}Accepts: title, role, description, link, tag, image{% endcomment %}
<article class="msc-profile-card msc-glass-card">
  {%- if link != blank -%}<a class="msc-profile-card__link" href="{{ link }}">{%- else -%}<div class="msc-profile-card__link msc-profile-card__link--static">{%- endif -%}
    {%- if image != blank -%}
      <div class="msc-profile-card__media">{{ image | image_url: width: 720 | image_tag: loading: 'lazy', alt: title }}</div>
    {%- endif -%}
    <span class="msc-profile-card__tag">{{ tag | default: 'Profile' | escape }}</span>
    <h3>{{ title | escape }}</h3>
    {%- if role != blank -%}<p class="msc-profile-card__role">{{ role | escape }}</p>{%- endif -%}
    {%- if description != blank -%}<p class="msc-profile-card__description">{{ description | escape }}</p>{%- endif -%}
  {%- if link != blank -%}</a>{%- else -%}</div>{%- endif -%}
</article>
