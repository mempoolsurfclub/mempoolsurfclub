{% comment %}Accepts: title, role, description, link, tag{% endcomment %}
<article class="msc-profile-card msc-glass-card">
  <a class="msc-profile-card__link" href="{{ link | default: '#MainContent' }}">
    <span class="msc-profile-card__orb" aria-hidden="true"></span>
    <span class="msc-profile-card__tag">{{ tag | default: 'Profile' | escape }}</span>
    <h3>{{ title | escape }}</h3>
    {%- if role != blank -%}<p class="msc-profile-card__role">{{ role | escape }}</p>{%- endif -%}
    {%- if description != blank -%}<p class="msc-profile-card__description">{{ description | escape }}</p>{%- endif -%}
  </a>
</article>
