{% comment %}Accepts: title, description, link, meta, action_label{% endcomment %}
{%- assign has_link = false -%}
{%- if link != blank -%}{%- assign has_link = true -%}{%- endif -%}
{%- if has_link -%}
  <a class="msc-category-card msc-category-card--link msc-glass-card" href="{{ link }}" data-current="{{ meta | default: 'Index' | handleize }}">
{%- else -%}
  <article class="msc-category-card msc-category-card--static msc-glass-card" data-current="{{ meta | default: 'Index' | handleize }}">
{%- endif -%}
  <span class="msc-category-card__meta">{{ meta | default: 'Index' | escape }}</span>
  <span class="msc-category-card__title">{{ title | escape }}</span>
  {%- if description != blank -%}<span class="msc-category-card__description">{{ description | escape }}</span>{%- endif -%}
  {%- assign rendered_action_label = action_label | default: 'Explore category' -%}
  <span class="msc-card-arrow">{{ rendered_action_label | downcase | capitalize }} <span aria-hidden="true">→</span></span>
{%- if has_link -%}
  </a>
{%- else -%}
  </article>
{%- endif -%}
