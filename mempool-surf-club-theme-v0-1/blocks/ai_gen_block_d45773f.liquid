{% doc %}
  @prompt
    I have 9 images that i would like to display 3 x 3, i need them to be clickable and link to there respective page, can you match the ratio of the image that i uploaded for the 1st image, can you give me the option to match the ratio size of the image file, can you fix the sizing of the images i have attached. it looks like your placeholder for the images crops out or zooms in too much
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-image-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-image-grid__item-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ block.settings.border_radius }}px;
    display: block;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }

  .ai-image-grid__item-{{ ai_gen_id }}:hover {
    transform: scale({{ block.settings.hover_scale }});
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .ai-image-grid__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-image-grid__placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-grid__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-image-grid__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<image-grid-{{ ai_gen_id }} class="ai-image-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-grid__container-{{ ai_gen_id }}">
    {% for i in (1..9) %}
      {% liquid
        assign image_key = 'image_' | append: i
        assign link_key = 'link_' | append: i
        assign image = block.settings[image_key]
        assign link = block.settings[link_key]
      %}

      {% if link != blank %}
        <a href="{{ link }}" class="ai-image-grid__item-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-image-grid__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-image-grid__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </a>
      {% else %}
        <div class="ai-image-grid__item-{{ ai_gen_id }}">
          {% if image %}
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | escape }}"
              loading="lazy"
              width="{{ image.width }}"
              height="{{ image.height }}"
              class="ai-image-grid__image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-image-grid__placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</image-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('image-grid-{{ ai_gen_id }}', ImageGrid{{ ai_gen_id }});
  })();
</script>

