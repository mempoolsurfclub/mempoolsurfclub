{% doc %}
  @prompt
    Create a search bar section that allows customers to search content within the website. It should have a clean, modern design with a text input field and a search button. The search should link to the store's native search functionality (/search?q=). The section should be customizable with options for placeholder text, background color, and alignment.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-search-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-search-bar-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    text-align: {{ block.settings.alignment }};
  }

  .ai-search-bar-form-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: stretch;
    width: 100%;
    max-width: {{ block.settings.search_bar_width }}px;
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.input_background_color }};
    box-shadow: 0 2px 8px rgba(0, 0, 0, {{ block.settings.shadow_opacity }});
  }

  .ai-search-bar-input-{{ ai_gen_id }} {
    flex: 1;
    padding: {{ block.settings.input_padding }}px 20px;
    border: none;
    background: transparent;
    font-size: {{ block.settings.input_font_size }}px;
    color: {{ block.settings.input_text_color }};
    outline: none;
  }

  .ai-search-bar-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.placeholder_color }};
    opacity: 0.7;
  }

  .ai-search-bar-button-{{ ai_gen_id }} {
    padding: {{ block.settings.input_padding }}px 30px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    cursor: pointer;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-search-bar-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-search-bar-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
  }

  @media screen and (max-width: 749px) {
    .ai-search-bar-form-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-search-bar-button-{{ ai_gen_id }} {
      padding: {{ block.settings.input_padding }}px 20px;
    }

    .ai-search-bar-button-text-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<search-bar-{{ ai_gen_id }} class="ai-search-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-search-bar-container-{{ ai_gen_id }}">
    <form action="/search" method="get" class="ai-search-bar-form-{{ ai_gen_id }}" role="search">
      <input
        type="search"
        name="q"
        class="ai-search-bar-input-{{ ai_gen_id }}"
        placeholder="{{ block.settings.placeholder_text }}"
        aria-label="Search"
        autocomplete="off"
      >
      <button type="submit" class="ai-search-bar-button-{{ ai_gen_id }}" aria-label="Search">
        <svg class="ai-search-bar-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
        <span class="ai-search-bar-button-text-{{ ai_gen_id }}">{{ block.settings.button_text }}</span>
      </button>
    </form>
  </div>
</search-bar-{{ ai_gen_id }}>

<script>
  (function() {
    class SearchBar{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.form = this.querySelector('.ai-search-bar-form-{{ ai_gen_id }}');
        this.input = this.querySelector('.ai-search-bar-input-{{ ai_gen_id }}');
        
        if (this.form && this.input) {
          this.form.addEventListener('submit', this.handleSubmit.bind(this));
        }
      }

      handleSubmit(event) {
        if (!this.input.value.trim()) {
          event.preventDefault();
          this.input.focus();
        }
      }
    }

    customElements.define('search-bar-{{ ai_gen_id }}', SearchBar{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Search bar",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Search bar"
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Placeholder text",
      "default": "Search our store..."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Search"
    },
    {
      "type": "range",
      "id": "search_bar_width",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Search bar width",
      "default": 600
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "Input background",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "input_text_color",
      "label": "Input text",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "placeholder_color",
      "label": "Placeholder text",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover background",
      "default": "#4e6b71"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Section padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Container max width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "input_padding",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Input padding",
      "default": 14
    },
    {
      "type": "range",
      "id": "input_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Input font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Button font size",
      "default": 16
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 8
    },
    {
      "type": "range",
      "id": "border_thickness",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "Border thickness",
      "default": 1
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "min": 0,
      "max": 0.5,
      "step": 0.1,
      "label": "Shadow opacity",
      "default": 0.1
    }
  ],
  "presets": [
    {
      "name": "Search bar"
    }
  ]
}
{% endschema %}
