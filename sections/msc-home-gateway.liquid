{{ 'mempool-ui.css' | asset_url | stylesheet_tag }}

<section class="msc-shell msc-home-gateway" id="MscHomeGateway-{{ section.id }}">
  <div class="msc-container">
    <div class="msc-section-header">
      {%- if section.settings.kicker != blank -%}<p class="msc-section-kicker">{{ section.settings.kicker | escape }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="msc-section-title">{{ section.settings.heading | escape }}</h2>{%- endif -%}
      {%- if section.settings.copy != blank -%}<div class="msc-section-header__copy rte">{{ section.settings.copy }}</div>{%- endif -%}
    </div>

    <div class="msc-home-gateway__grid">
      {%- for block in section.blocks -%}
        <div class="msc-gateway-card msc-glass-card msc-gateway-card--{{ forloop.index }}{% if block.settings.link == blank %} msc-gateway-card--disabled{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}<a class="msc-gateway-card__link" href="{{ block.settings.link }}">{%- else -%}<div class="msc-gateway-card__link">{%- endif -%}
            <div class="msc-gateway-card__top">
              <span>{{ block.settings.route_label | escape }}</span>
              <i aria-hidden="true"></i>
            </div>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', class: 'msc-gateway-card__image', sizes: '(min-width: 990px) 25vw, 100vw', widths: '240, 360, 520, 700' }}
            {%- endif -%}
            <h3>{{ block.settings.title | escape }}</h3>
            <p>{{ block.settings.description | escape }}</p>
            {%- if block.settings.action_label != blank -%}<span class="msc-card-arrow">{{ block.settings.action_label | escape }} →</span>{%- endif -%}
          {%- if block.settings.link != blank -%}</a>{%- else -%}</div>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="msc-network-preview msc-glass-card">
      <div class="msc-network-preview__copy">
        {%- if section.settings.tools_kicker != blank -%}<p class="msc-section-kicker">{{ section.settings.tools_kicker | escape }}</p>{%- endif -%}
        {%- if section.settings.tools_heading != blank -%}<h2 class="msc-section-title">{{ section.settings.tools_heading | escape }}</h2>{%- endif -%}
        {%- if section.settings.tools_copy != blank -%}<div class="rte">{{ section.settings.tools_copy }}</div>{%- endif -%}
        {%- if section.settings.tools_button_label != blank and section.settings.tools_button_link != blank -%}
          <a class="msc-button msc-button--secondary" href="{{ section.settings.tools_button_link }}">{{ section.settings.tools_button_label | escape }}</a>
        {%- endif -%}
      </div>
      <div class="msc-network-preview__signals" aria-label="Network concepts preview">
        <div><strong>Fees</strong><p>Understand fee conditions and how urgently transactions are competing for confirmation.</p></div>
        <div><strong>Mempool</strong><p>See how much transaction demand is waiting for limited blockspace.</p></div>
        <div><strong>Mining</strong><p>Follow hashrate and difficulty conditions without turning the network into market hype.</p></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MSC home gateway",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "ENTER THE ECOSYSTEM" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Four ways to move through the same ocean." },
    { "type": "richtext", "id": "copy", "label": "Supporting copy", "default": "<p>Explore the culture, learn how Bitcoin works, read network conditions, and discover physical collections built around the ideas moving through it.</p>" },
    { "type": "text", "id": "tools_kicker", "label": "Tools preview kicker", "default": "READ THE NETWORK" },
    { "type": "text", "id": "tools_heading", "label": "Tools preview heading", "default": "Know what conditions matter before you move." },
    { "type": "richtext", "id": "tools_copy", "label": "Tools preview copy", "default": "<p>Fees, transaction demand, mining conditions, and blockspace all reveal a different part of the network.</p>" },
    { "type": "text", "id": "tools_button_label", "label": "Tools button label", "default": "Open network tools" },
    { "type": "url", "id": "tools_button_link", "label": "Tools button link" }
  ],
  "blocks": [
    {
      "type": "destination",
      "name": "Destination",
      "settings": [
        { "type": "text", "id": "route_label", "label": "Route label", "default": "01 — Route" },
        { "type": "text", "id": "title", "label": "Title", "default": "Explore" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Profiles, projects, editorials, art, companies, and cultural signals shaping Bitcoin." },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text", "id": "action_label", "label": "Action label", "default": "Explore the culture" },
        { "type": "image_picker", "id": "image", "label": "Optional image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "MSC home gateway",
      "settings": { "tools_button_link": "shopify://pages/tools" },
      "blocks": [
        { "type": "destination", "settings": { "route_label": "01 — Explore", "title": "Explore", "description": "Profiles, projects, editorials, art, companies, and cultural signals shaping Bitcoin.", "action_label": "Explore the culture", "link": "shopify://pages/explore" } },
        { "type": "destination", "settings": { "route_label": "02 — Learn", "title": "Learn", "description": "Clear routes through Bitcoin fundamentals, the network, development, and the wider ecosystem.", "action_label": "Open the field guide", "link": "shopify://pages/learn" } },
        { "type": "destination", "settings": { "route_label": "03 — Tools", "title": "Tools", "description": "Interfaces designed to help read fees, blockspace, mempool pressure, mining conditions, and network movement.", "action_label": "Read the network", "link": "shopify://pages/tools" } },
        { "type": "destination", "settings": { "route_label": "04 — Shop", "title": "Shop", "description": "MSC releases and independent collections from artists, builders, projects, and collaborators.", "action_label": "View the collections", "link": "shopify://pages/shop" } }
      ]
    }
  ]
}
{% endschema %}
