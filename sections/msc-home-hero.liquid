{{ 'mempool-ui.css' | asset_url | stylesheet_tag }}

{%- assign search_input_id = 'MscHomeSearchInput-' | append: section.id -%}

<section class="msc-shell msc-home-hero" id="MscHomeHero-{{ section.id }}">
  <div class="msc-container">
    <div class="msc-home-hero__grid">
      <div class="msc-home-hero__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="msc-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="msc-title msc-home-hero__title">{{ section.settings.heading | escape }}</h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <div class="msc-subtitle msc-home-hero__subtitle rte">
            {{ section.settings.subheading }}
          </div>
        {%- endif -%}

        {% render 'msc-search-form',
          input_id: search_input_id,
          placeholder: section.settings.search_placeholder,
          button_label: section.settings.search_button,
          search_types: section.settings.search_types,
          label: section.settings.search_label,
          modifier: 'home'
        %}

        <div class="msc-home-hero__actions" aria-label="Primary homepage actions">
          {%- if section.settings.primary_button_label != blank -%}
            <a class="msc-button" href="{{ section.settings.primary_button_link | default: routes.root_url }}">
              {{ section.settings.primary_button_label | escape }}
            </a>
          {%- endif -%}
          {%- if section.settings.secondary_button_label != blank -%}
            <a class="msc-button msc-button--secondary" href="{{ section.settings.secondary_button_link | default: routes.root_url }}">
              {{ section.settings.secondary_button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="msc-signal-card msc-glass-card" aria-label="Bitcoin network signal visualization">
        <div class="msc-signal-card__header">
          <span>MSC SIGNAL FIELD</span>
          <span>Listening</span>
        </div>
        <div class="msc-signal-field" aria-hidden="true">
          <span class="msc-signal-field__node msc-signal-field__node--one"></span>
          <span class="msc-signal-field__node msc-signal-field__node--two"></span>
          <span class="msc-signal-field__node msc-signal-field__node--three"></span>
          <span class="msc-signal-field__node msc-signal-field__node--four"></span>
          <span class="msc-signal-field__line msc-signal-field__line--one"></span>
          <span class="msc-signal-field__line msc-signal-field__line--two"></span>
          <span class="msc-signal-field__line msc-signal-field__line--three"></span>
        </div>
        <div class="msc-signal-card__footer">
          <span>Education</span>
          <span>Culture</span>
          <span>Tools</span>
          <span>Research</span>
        </div>
      </div>
    </div>

    <div class="msc-network-pulse" aria-labelledby="MscNetworkPulseTitle-{{ section.id }}">
      <div class="msc-network-pulse__heading">
        <p class="msc-section-kicker">{{ section.settings.pulse_kicker | escape }}</p>
        <h2 class="msc-section-title" id="MscNetworkPulseTitle-{{ section.id }}">{{ section.settings.pulse_heading | escape }}</h2>
      </div>
      <div class="msc-status-grid msc-status-grid--pulse">
        {% render 'msc-metric-card', label: 'Next Block', value: 'Connecting', note: 'Awaiting live block feed', status: 'Fallback' %}
        {% render 'msc-metric-card', label: 'Priority Fee', value: '—', note: 'sat/vB pending', status: 'Fallback' %}
        {% render 'msc-metric-card', label: 'Mempool', value: '—', note: 'Virtual bytes pending', status: 'Fallback' %}
        {% render 'msc-metric-card', label: 'Hashrate', value: '—', note: 'EH/s feed pending', status: 'Fallback' %}
        {% render 'msc-metric-card', label: 'Difficulty Adjustment', value: '—', note: 'Epoch estimate pending', status: 'Fallback' %}
        {% render 'msc-metric-card', label: 'BTC Price', value: '—', note: 'Market feed pending', status: 'Fallback' %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MSC home hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Live-status eyebrow",
      "default": "LIVE FROM THE BITCOIN NETWORK"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "READ THE NETWORK. EXPLORE THE CULTURE."
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Supporting copy",
      "default": "<p>Mempool Surf Club is a place to explore Bitcoin culture, learn how Bitcoin and its ecosystem work, and view current network conditions.</p>"
    },
    {
      "type": "text",
      "id": "search_label",
      "label": "Search accessible label",
      "default": "Search editorials, people, companies, artists, tools, and educational topics"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search editorials, people, companies, artists, tools, and topics..."
    },
    {
      "type": "text",
      "id": "search_button",
      "label": "Search button",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "search_types",
      "label": "Shopify search types",
      "default": "article,page,product"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Explore the ecosystem"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Open network tools"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "pulse_kicker",
      "label": "Network pulse kicker",
      "default": "Network Pulse"
    },
    {
      "type": "text",
      "id": "pulse_heading",
      "label": "Network pulse heading",
      "default": "Current conditions, ready for live data."
    }
  ],
  "presets": [
    {
      "name": "MSC home hero"
    }
  ]
}
{% endschema %}
