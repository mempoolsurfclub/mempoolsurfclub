{{ 'mempool-ui.css' | asset_url | stylesheet_tag }}

{%- assign search_input_id = 'MscHomeSearchInput-' | append: section.id -%}
{%- assign heading_line_1 = section.settings.heading_line_1 | default: blank -%}
{%- assign heading_line_2 = section.settings.heading_line_2 | default: blank -%}

<section class="msc-shell msc-home-hero" id="MscHomeHero-{{ section.id }}">
  <div class="msc-container">
    <div class="msc-home-hero__grid">
      <div class="msc-home-hero__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="msc-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if heading_line_1 != blank or heading_line_2 != blank -%}
          <h1 class="msc-title msc-home-hero__title">
            {%- if heading_line_1 != blank -%}<span>{{ heading_line_1 | escape }}</span>{%- endif -%}
            {%- if heading_line_2 != blank -%}<span>{{ heading_line_2 | escape }}</span>{%- endif -%}
          </h1>
        {%- elsif section.settings.heading != blank -%}
          <h1 class="msc-title msc-home-hero__title">{{ section.settings.heading | escape }}</h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <div class="msc-subtitle msc-home-hero__subtitle rte">
            {{ section.settings.subheading }}
          </div>
        {%- endif -%}

        {% render 'msc-search-form',
          input_id: search_input_id,
          placeholder: section.settings.search_placeholder,
          button_label: section.settings.search_button,
          search_types: section.settings.search_types,
          label: section.settings.search_label,
          modifier: 'home'
        %}

        <div class="msc-home-hero__actions" aria-label="Primary homepage actions">
          {%- if section.settings.primary_button_label != blank and section.settings.primary_button_link != blank -%}
            <a class="msc-button" href="{{ section.settings.primary_button_link }}">
              {{ section.settings.primary_button_label | escape }}
            </a>
          {%- endif -%}
          {%- if section.settings.secondary_button_label != blank and section.settings.secondary_button_link != blank -%}
            <a class="msc-button msc-button--secondary" href="{{ section.settings.secondary_button_link }}">
              {{ section.settings.secondary_button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>

      <div class="msc-signal-card msc-glass-card" role="img" aria-label="Mempool Surf Club ecosystem map showing Explore, Learn, Tools, and Shop destinations.">
        <div class="msc-signal-card__header">
          <span>MSC ECOSYSTEM MAP</span>
          <span>OBSERVING</span>
        </div>
        <div class="msc-signal-field" aria-hidden="true">
          <span class="msc-signal-field__line msc-signal-field__line--one"></span>
          <span class="msc-signal-field__line msc-signal-field__line--two"></span>
          <span class="msc-signal-field__line msc-signal-field__line--three"></span>
          <span class="msc-signal-field__node msc-signal-field__node--one"><i></i><strong>EXPLORE</strong><small>CULTURE</small></span>
          <span class="msc-signal-field__node msc-signal-field__node--two"><i></i><strong>LEARN</strong><small>EDUCATION</small></span>
          <span class="msc-signal-field__node msc-signal-field__node--three"><i></i><strong>TOOLS</strong><small>NETWORK</small></span>
          <span class="msc-signal-field__node msc-signal-field__node--four"><i></i><strong>SHOP</strong><small>OBJECTS</small></span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MSC home hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Hero eyebrow", "default": "BITCOIN CULTURE + NETWORK" },
    { "type": "text", "id": "heading_line_1", "label": "Heading line 1", "default": "READ THE NETWORK." },
    { "type": "text", "id": "heading_line_2", "label": "Heading line 2", "default": "EXPLORE THE CULTURE." },
    { "type": "text", "id": "heading", "label": "Legacy heading fallback", "default": "READ THE NETWORK. EXPLORE THE CULTURE." },
    { "type": "richtext", "id": "subheading", "label": "Supporting copy", "default": "<p>Mempool Surf Club is a place to explore Bitcoin culture, understand how the network works, read the conditions shaping it, and discover objects that carry the culture forward.</p>" },
    { "type": "text", "id": "search_label", "label": "Search accessible label", "default": "Search people, projects, ideas, tools, and topics" },
    { "type": "text", "id": "search_placeholder", "label": "Search placeholder", "default": "Search people, projects, ideas, tools, and topics..." },
    { "type": "text", "id": "search_button", "label": "Search button", "default": "Search" },
    { "type": "text", "id": "search_types", "label": "Shopify search types", "default": "article,page,product" },
    { "type": "text", "id": "primary_button_label", "label": "Primary button label", "default": "Explore the ecosystem" },
    { "type": "url", "id": "primary_button_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_button_label", "label": "Secondary button label", "default": "Start learning" },
    { "type": "url", "id": "secondary_button_link", "label": "Secondary button link" }
  ],
  "presets": [{ "name": "MSC home hero", "settings": { "primary_button_link": "shopify://pages/explore", "secondary_button_link": "shopify://pages/learn" } }]
}
{% endschema %}
