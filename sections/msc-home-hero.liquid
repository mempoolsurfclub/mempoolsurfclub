{{ 'mempool-ui.css' | asset_url | stylesheet_tag }}

{%- assign search_input_id = 'MscHomeSearchInput-' | append: section.id -%}
{%- assign heading_line_1 = section.settings.heading_line_1 | default: blank -%}
{%- assign heading_line_2 = section.settings.heading_line_2 | default: blank -%}

<section class="msc-shell msc-home-hero" id="MscHomeHero-{{ section.id }}">
  <div class="msc-container">
    <div class="msc-home-hero__grid">
      <div class="msc-home-hero__content">
        <div class="msc-eyebrow msc-rotating-signal" aria-label="{{ section.settings.signal_phrase_1 | escape }}">
          <span class="msc-rotating-signal__indicator" aria-hidden="true"></span>
          <span class="msc-rotating-signal__phrases">
            <span>{{ section.settings.signal_phrase_1 | escape }}</span>
            <span>{{ section.settings.signal_phrase_2 | escape }}</span>
            <span>{{ section.settings.signal_phrase_3 | escape }}</span>
          </span>
        </div>

        {%- if heading_line_1 != blank or heading_line_2 != blank -%}
          <h1 class="msc-title msc-home-hero__title">
            {%- if heading_line_1 != blank -%}<span>{{ heading_line_1 | escape }}</span>{%- endif -%}
            {%- if heading_line_2 != blank -%}<span>{{ heading_line_2 | escape }}</span>{%- endif -%}
          </h1>
        {%- elsif section.settings.heading != blank -%}
          <h1 class="msc-title msc-home-hero__title">{{ section.settings.heading | escape }}</h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <div class="msc-subtitle msc-home-hero__subtitle rte">
            {{ section.settings.subheading }}
          </div>
        {%- endif -%}

        {% render 'msc-search-form',
          input_id: search_input_id,
          placeholder: section.settings.search_placeholder,
          button_label: section.settings.search_button,
          search_types: section.settings.search_types,
          label: section.settings.search_label,
          modifier: 'home'
        %}

      </div>

      <div class="msc-signal-card msc-glass-card" aria-label="Mempool Surf Club ecosystem radar linking to Explore, Learn, Tools, and Shop destinations.">
        <div class="msc-signal-card__header">
          <span>MSC ECOSYSTEM RADAR</span>
          <span class="msc-signal-card__status">SCANNING</span>
        </div>
        <div class="msc-signal-field">
          <span class="msc-signal-field__radar-disc" aria-hidden="true">
            <span class="msc-signal-field__bitcoin-mark" aria-hidden="true">₿</span>
          </span>
          <a class="msc-signal-field__node msc-signal-field__node--one" href="shopify://pages/explore"><i aria-hidden="true"></i><strong>Explore</strong></a>
          <a class="msc-signal-field__node msc-signal-field__node--two" href="shopify://pages/learn"><i aria-hidden="true"></i><strong>Learn</strong></a>
          <a class="msc-signal-field__node msc-signal-field__node--three" href="shopify://pages/tools"><i aria-hidden="true"></i><strong>Tools</strong></a>
          <a class="msc-signal-field__node msc-signal-field__node--four" href="shopify://pages/shop"><i aria-hidden="true"></i><strong>Shop</strong></a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MSC home hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "signal_phrase_1", "label": "Signal phrase 1", "default": "SCANNING THE BITCOIN ECOSYSTEM" },
    { "type": "text", "id": "signal_phrase_2", "label": "Signal phrase 2", "default": "READING NETWORK + CULTURE SIGNALS" },
    { "type": "text", "id": "signal_phrase_3", "label": "Signal phrase 3", "default": "WATCHING THE MEMPOOL" },
    { "type": "text", "id": "heading_line_1", "label": "Heading line 1", "default": "READ THE NETWORK." },
    { "type": "text", "id": "heading_line_2", "label": "Heading line 2", "default": "RIDE THE WAVE." },
    { "type": "text", "id": "heading", "label": "Legacy heading fallback", "default": "READ THE NETWORK. RIDE THE WAVE." },
    { "type": "richtext", "id": "subheading", "label": "Supporting copy", "default": "<p>Mempool Surf Club is a place to explore Bitcoin culture, understand how the network works, read the conditions shaping it, and discover the people who carry the culture forward.</p>" },
    { "type": "text", "id": "search_label", "label": "Search accessible label", "default": "Search people, projects, ideas, tools, and topics" },
    { "type": "text", "id": "search_placeholder", "label": "Search placeholder", "default": "Search people, projects, ideas, tools, and topics..." },
    { "type": "text", "id": "search_button", "label": "Search button", "default": "Search" },
    { "type": "text", "id": "search_types", "label": "Shopify search types", "default": "article,page,product" }
  ],
  "presets": [{ "name": "MSC home hero" }]
}
{% endschema %}
