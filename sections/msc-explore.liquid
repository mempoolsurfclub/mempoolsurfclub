{{ 'mempool-ui.css' | asset_url | stylesheet_tag }}

{%- assign search_input_id = 'MscExploreSearchInput-' | append: section.id -%}
{%- assign recent_count = 0 -%}
{%- for block in section.blocks -%}
  {%- if block.type == 'recent' -%}{%- assign recent_count = recent_count | plus: 1 -%}{%- endif -%}
{%- endfor -%}
{%- assign content_blog = section.settings.content_blog -%}
{%- assign breaking_window_seconds = section.settings.breaking_news_hours | times: 3600 -%}
{%- assign current_timestamp = 'now' | date: '%s' | plus: 0 -%}

<section class="msc-shell msc-explore" id="MscExplore-{{ section.id }}">
  <div class="msc-container">
    <div class="msc-explore-hero">
      <div class="msc-explore-hero__content">
        <div class="msc-eyebrow msc-rotating-signal" aria-label="{{ section.settings.signal_phrase_1 | escape }}">
          <span class="msc-rotating-signal__indicator" aria-hidden="true"></span>
          <span class="msc-rotating-signal__phrases"><span>{{ section.settings.signal_phrase_1 | escape }}</span><span>{{ section.settings.signal_phrase_2 | escape }}</span><span>{{ section.settings.signal_phrase_3 | escape }}</span></span>
        </div>
        <h1 class="msc-title msc-explore-hero__title">{{ section.settings.heading | escape }}</h1>
        <div class="msc-subtitle msc-explore-hero__copy rte">{{ section.settings.supporting_copy }}</div>
        {% render 'msc-search-form', input_id: search_input_id, placeholder: section.settings.search_placeholder, button_label: section.settings.search_button, search_types: section.settings.search_types, label: section.settings.search_label, modifier: 'explore' %}
      </div>
      <div class="msc-discovery-map msc-glass-card" aria-label="Bitcoin Culture Wave Map visual">
        <div class="msc-discovery-map__header"><span>Bitcoin Culture Wave Map</span><span>Current Index</span></div>
        <div class="msc-discovery-map__field">
          <svg class="msc-discovery-map__chart" viewBox="0 0 720 420" preserveAspectRatio="none" focusable="false" aria-hidden="true"><path class="msc-discovery-map__wave msc-discovery-map__wave--macro" d="M 24 244 C 110 118 208 118 294 244 S 478 370 568 244 S 662 145 696 176" /><path class="msc-discovery-map__wave msc-discovery-map__wave--ripple" d="M 20 166 C 52 126 84 126 116 166 S 180 206 212 166 S 276 126 308 166 S 372 206 404 166 S 468 126 500 166 S 564 206 596 166 S 660 126 700 166" /><path class="msc-discovery-map__wave msc-discovery-map__wave--current" d="M 28 306 C 116 274 154 214 224 226 C 316 242 332 326 424 300 C 504 278 532 202 610 214 C 648 220 674 244 700 268" /></svg>
          {%- if section.settings.map_companies_link != blank -%}<a class="msc-discovery-map__node msc-discovery-map__node--companies" href="{{ section.settings.map_companies_link }}">{%- else -%}<span class="msc-discovery-map__node msc-discovery-map__node--companies">{%- endif -%}<i aria-hidden="true"></i><strong>Companies</strong>{%- if section.settings.map_companies_link != blank -%}</a>{%- else -%}</span>{%- endif -%}
          {%- if section.settings.map_art_link != blank -%}<a class="msc-discovery-map__node msc-discovery-map__node--art" href="{{ section.settings.map_art_link }}">{%- else -%}<span class="msc-discovery-map__node msc-discovery-map__node--art">{%- endif -%}<i aria-hidden="true"></i><strong>Art</strong>{%- if section.settings.map_art_link != blank -%}</a>{%- else -%}</span>{%- endif -%}
          {%- if section.settings.map_builders_link != blank -%}<a class="msc-discovery-map__node msc-discovery-map__node--builders" href="{{ section.settings.map_builders_link }}">{%- else -%}<span class="msc-discovery-map__node msc-discovery-map__node--builders">{%- endif -%}<i aria-hidden="true"></i><strong>Builders</strong>{%- if section.settings.map_builders_link != blank -%}</a>{%- else -%}</span>{%- endif -%}
        </div>
      </div>
    </div>

    <nav class="msc-explore-categories" aria-label="Explore categories">
      {%- for block in section.blocks -%}{%- if block.type == 'category' -%}{% render 'msc-category-card', title: block.settings.title, description: block.settings.description, link: block.settings.link, meta: block.settings.meta, action_label: block.settings.action_label %}{%- endif -%}{%- endfor -%}
    </nav>

    <div class="msc-block" aria-labelledby="MscExploreEditorials-{{ section.id }}">
      {% render 'msc-section-header', kicker: section.settings.editorial_kicker, heading: section.settings.editorial_heading, copy: section.settings.editorial_copy, heading_id: 'MscExploreEditorials-' | append: section.id %}
      {%- assign stories_rendered = 0 -%}
      {%- if content_blog != blank and content_blog.articles_count > 0 -%}<div class="msc-editorial-layout">
        {%- for article in content_blog.articles -%}
          {%- if stories_rendered >= section.settings.stories_limit -%}{%- break -%}{%- endif -%}
          {%- assign article_tag_handles = '|' -%}{%- for tag in article.tags -%}{%- assign article_tag_handles = article_tag_handles | append: tag | handleize | append: '|' -%}{%- endfor -%}
          {%- assign primary_label = '' -%}{%- assign breaking_handle = section.settings.breaking_news_tag | handleize | prepend: '|' | append: '|' -%}{%- assign weekly_handle = section.settings.weekly_recaps_tag | handleize | prepend: '|' | append: '|' -%}{%- assign interviews_handle = section.settings.interviews_tag | handleize | prepend: '|' | append: '|' -%}{%- assign highlights_handle = section.settings.highlights_tag | handleize | prepend: '|' | append: '|' -%}{%- assign community_handle = section.settings.community_tag | handleize | prepend: '|' | append: '|' -%}
          {%- if article_tag_handles contains breaking_handle -%}{%- assign primary_label = section.settings.breaking_news_tag -%}{%- elsif article_tag_handles contains weekly_handle -%}{%- assign primary_label = section.settings.weekly_recaps_tag -%}{%- elsif article_tag_handles contains interviews_handle -%}{%- assign primary_label = section.settings.interviews_tag -%}{%- elsif article_tag_handles contains highlights_handle -%}{%- assign primary_label = section.settings.highlights_tag -%}{%- elsif article_tag_handles contains community_handle -%}{%- assign primary_label = section.settings.community_tag -%}{%- endif -%}
          {%- if primary_label != blank -%}{%- assign is_visible_breaking = true -%}{%- if primary_label == section.settings.breaking_news_tag -%}{%- assign article_timestamp = article.published_at | date: '%s' | plus: 0 -%}{%- assign article_age = current_timestamp | minus: article_timestamp -%}{%- if article_age > breaking_window_seconds -%}{%- assign is_visible_breaking = false -%}{%- endif -%}{%- endif -%}{%- if is_visible_breaking -%}{%- assign stories_rendered = stories_rendered | plus: 1 -%}{%- assign story_card_size = 'standard' -%}{%- if stories_rendered == 1 -%}{%- assign story_card_size = 'lead' -%}{%- endif -%}{% render 'msc-editorial-card', article: article, label: primary_label, size: story_card_size %}{%- endif -%}{%- endif -%}
        {%- endfor -%}</div>{%- endif -%}
      {%- if stories_rendered == 0 -%}{% render 'msc-explore-empty-state', label: section.settings.editorial_empty_label, heading: section.settings.editorial_empty_heading, copy: section.settings.editorial_empty_copy %}{%- endif -%}
    </div>

    <div class="msc-block" aria-labelledby="MscExploreDiscovery-{{ section.id }}">
      {% render 'msc-section-header', kicker: section.settings.discovery_kicker, heading: section.settings.discovery_heading, copy: section.settings.discovery_copy, heading_id: 'MscExploreDiscovery-' | append: section.id %}
      {%- assign culture_rendered = 0 -%}
      {%- if content_blog != blank and content_blog.articles_count > 0 -%}<div class="msc-profile-grid">
        {%- for article in content_blog.articles -%}
          {%- if culture_rendered >= section.settings.culture_index_limit -%}{%- break -%}{%- endif -%}
          {%- assign article_tag_handles = '|' -%}{%- for tag in article.tags -%}{%- assign article_tag_handles = article_tag_handles | append: tag | handleize | append: '|' -%}{%- endfor -%}
          {%- assign primary_label = '' -%}{%- assign breaking_handle = section.settings.breaking_news_tag | handleize | prepend: '|' | append: '|' -%}{%- assign weekly_handle = section.settings.weekly_recaps_tag | handleize | prepend: '|' | append: '|' -%}{%- assign interviews_handle = section.settings.interviews_tag | handleize | prepend: '|' | append: '|' -%}{%- assign highlights_handle = section.settings.highlights_tag | handleize | prepend: '|' | append: '|' -%}{%- assign community_handle = section.settings.community_tag | handleize | prepend: '|' | append: '|' -%}
          {%- if article_tag_handles contains breaking_handle -%}{%- assign primary_label = section.settings.breaking_news_tag -%}{%- elsif article_tag_handles contains weekly_handle -%}{%- assign primary_label = section.settings.weekly_recaps_tag -%}{%- elsif article_tag_handles contains interviews_handle -%}{%- assign primary_label = section.settings.interviews_tag -%}{%- elsif article_tag_handles contains highlights_handle -%}{%- assign primary_label = section.settings.highlights_tag -%}{%- elsif article_tag_handles contains community_handle -%}{%- assign primary_label = section.settings.community_tag -%}{%- endif -%}
          {%- assign culture_label = '' -%}{%- assign culture_routing_tags = section.settings.culture_index_tags | split: ',' -%}{%- if primary_label != blank -%}{%- for routing_tag in culture_routing_tags -%}{%- assign routing_tag_clean = routing_tag | strip -%}{%- if routing_tag_clean != blank -%}{%- assign routing_handle = routing_tag_clean | handleize | prepend: '|' | append: '|' -%}{%- if article_tag_handles contains routing_handle and culture_label == blank -%}{%- assign culture_label = routing_tag_clean -%}{%- endif -%}{%- endif -%}{%- endfor -%}{%- endif -%}
          {%- if culture_label != blank -%}{%- assign is_visible_breaking = true -%}{%- if primary_label == section.settings.breaking_news_tag -%}{%- assign article_timestamp = article.published_at | date: '%s' | plus: 0 -%}{%- assign article_age = current_timestamp | minus: article_timestamp -%}{%- if article_age > breaking_window_seconds -%}{%- assign is_visible_breaking = false -%}{%- endif -%}{%- endif -%}{%- if is_visible_breaking -%}{%- assign culture_rendered = culture_rendered | plus: 1 -%}{% render 'msc-profile-card', article: article, tag: culture_label %}{%- endif -%}{%- endif -%}
        {%- endfor -%}</div>{%- endif -%}
      {%- if culture_rendered == 0 -%}{% render 'msc-explore-empty-state', label: section.settings.discovery_empty_label, heading: section.settings.discovery_empty_heading, copy: section.settings.discovery_empty_copy %}{%- endif -%}
    </div>

    <div class="msc-block" aria-labelledby="MscExploreReports-{{ section.id }}">
      <div class="msc-report-panel msc-glass-card">
        {% render 'msc-section-header', kicker: section.settings.reports_kicker, heading: section.settings.reports_heading, copy: section.settings.reports_copy, heading_id: 'MscExploreReports-' | append: section.id %}
        {%- assign recaps_rendered = 0 -%}
        {%- if content_blog != blank and content_blog.articles_count > 0 -%}<div class="msc-report-panel__list">
          {%- assign weekly_handle = section.settings.weekly_recaps_tag | handleize | prepend: '|' | append: '|' -%}
          {%- for article in content_blog.articles -%}{%- if recaps_rendered >= section.settings.weekly_recaps_limit -%}{%- break -%}{%- endif -%}{%- assign article_tag_handles = '|' -%}{%- for tag in article.tags -%}{%- assign article_tag_handles = article_tag_handles | append: tag | handleize | append: '|' -%}{%- endfor -%}{%- if article_tag_handles contains weekly_handle -%}{%- assign recaps_rendered = recaps_rendered | plus: 1 -%}{% render 'msc-explore-recap-row', article: article, primary_tag: section.settings.weekly_recaps_tag %}{%- endif -%}{%- endfor -%}
        </div>{%- endif -%}
        {%- if recaps_rendered == 0 -%}{% render 'msc-explore-empty-state', label: section.settings.reports_empty_label, heading: section.settings.reports_empty_heading, copy: section.settings.reports_empty_copy, modifier: 'report' %}{%- endif -%}
      </div>
    </div>

    {%- if section.settings.show_recent and recent_count > 0 -%}<div class="msc-block" aria-labelledby="MscExploreRecent-{{ section.id }}">{% render 'msc-section-header', kicker: section.settings.recent_kicker, heading: section.settings.recent_heading, heading_id: 'MscExploreRecent-' | append: section.id %}<div class="msc-update-list">{%- for block in section.blocks -%}{%- if block.type == 'recent' -%}<div class="msc-update-row msc-glass-card"><strong>{{ block.settings.title | escape }}</strong><span>{{ block.settings.note | escape }}</span></div>{%- endif -%}{%- endfor -%}</div></div>{%- endif -%}
  </div>
</section>

{% schema %}
