{{ 'mempool-ui.css' | asset_url | stylesheet_tag }}

{%- assign search_input_id = 'MscExploreSearchInput-' | append: section.id -%}

<section class="msc-shell msc-explore" id="MscExplore-{{ section.id }}">
  <div class="msc-container">
    <div class="msc-explore-hero">
      <div class="msc-explore-hero__content">
        <p class="msc-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        <h1 class="msc-title msc-explore-hero__title">{{ section.settings.heading | escape }}</h1>
        <div class="msc-subtitle msc-explore-hero__copy rte">{{ section.settings.supporting_copy }}</div>
        {% render 'msc-search-form', input_id: search_input_id, placeholder: section.settings.search_placeholder, button_label: section.settings.search_button, search_types: section.settings.search_types, label: section.settings.search_label, modifier: 'explore' %}
      </div>
      <div class="msc-discovery-map msc-glass-card" aria-label="Cultural discovery network visual">
        <div class="msc-discovery-map__header"><span>Discovery Graph</span><span>Curated Index</span></div>
        <div class="msc-discovery-map__field" aria-hidden="true">
          <span class="msc-discovery-map__node msc-discovery-map__node--a">Art</span>
          <span class="msc-discovery-map__node msc-discovery-map__node--b">Builders</span>
          <span class="msc-discovery-map__node msc-discovery-map__node--c">Research</span>
          <span class="msc-discovery-map__node msc-discovery-map__node--d">Projects</span>
        </div>
        <p>{{ section.settings.visual_caption | escape }}</p>
      </div>
    </div>

    <nav class="msc-explore-categories" aria-label="Explore categories">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          {% render 'msc-category-card', title: block.settings.title, description: block.settings.description, link: block.settings.link, meta: block.settings.meta %}
        {%- endif -%}
      {%- endfor -%}
    </nav>

    <div class="msc-block" aria-labelledby="MscExploreEditorials-{{ section.id }}">
      {% render 'msc-section-header', kicker: section.settings.editorial_kicker, heading: section.settings.editorial_heading, copy: section.settings.editorial_copy, heading_id: 'MscExploreEditorials-' | append: section.id %}
      <div class="msc-editorial-layout">
        {%- for block in section.blocks -%}
          {%- if block.type == 'editorial' -%}
            {% render 'msc-editorial-card', title: block.settings.title, dek: block.settings.dek, label: block.settings.label, link: block.settings.link, meta: block.settings.meta, size: block.settings.size %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="msc-block" aria-labelledby="MscExploreDiscovery-{{ section.id }}">
      {% render 'msc-section-header', kicker: section.settings.discovery_kicker, heading: section.settings.discovery_heading, copy: section.settings.discovery_copy, heading_id: 'MscExploreDiscovery-' | append: section.id %}
      <div class="msc-profile-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'profile' -%}
            {% render 'msc-profile-card', title: block.settings.title, role: block.settings.role, description: block.settings.description, link: block.settings.link, tag: block.settings.tag %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="msc-block" aria-labelledby="MscExploreReports-{{ section.id }}">
      <div class="msc-report-panel msc-glass-card">
        {% render 'msc-section-header', kicker: section.settings.reports_kicker, heading: section.settings.reports_heading, copy: section.settings.reports_copy, heading_id: 'MscExploreReports-' | append: section.id %}
        <div class="msc-report-panel__list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'report' -%}
              <a class="msc-report-row" href="{{ block.settings.link | default: '#MainContent' }}"><span>{{ block.settings.month | escape }}</span><strong>{{ block.settings.title | escape }}</strong><em>{{ block.settings.status | escape }}</em></a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

    <div class="msc-block" aria-labelledby="MscExploreRecent-{{ section.id }}">
      {% render 'msc-section-header', kicker: section.settings.recent_kicker, heading: section.settings.recent_heading, heading_id: 'MscExploreRecent-' | append: section.id %}
      <div class="msc-update-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'recent' -%}
            <div class="msc-update-row msc-glass-card"><strong>{{ block.settings.title | escape }}</strong><span>{{ block.settings.note | escape }}</span></div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MSC Explore",
  "tag": "section",
  "class": "section",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"BITCOIN CULTURE INDEX"},
    {"type":"text","id":"heading","label":"Heading","default":"EXPLORE THE ECOSYSTEM."},
    {"type":"richtext","id":"supporting_copy","label":"Supporting copy","default":"<p>Browse a curated cultural map of artists, founders, companies, projects, editorials, monthly on-chain reports, and Bitcoin ecosystem subjects. Placeholder entries mark the shape of the future index.</p>"},
    {"type":"text","id":"search_label","label":"Search accessible label","default":"Search the Bitcoin culture index"},
    {"type":"text","id":"search_placeholder","label":"Search placeholder","default":"Search artists, founders, companies, projects, reports..."},
    {"type":"text","id":"search_button","label":"Search button","default":"Search"},
    {"type":"text","id":"search_types","label":"Shopify search types","default":"article,page,product"},
    {"type":"text","id":"visual_caption","label":"Visual caption","default":"A first-party MSC discovery layer for culture, research, and ecosystem profiles."},
    {"type":"text","id":"editorial_kicker","label":"Editorial kicker","default":"Featured Editorials"},
    {"type":"text","id":"editorial_heading","label":"Editorial heading","default":"Stories for navigating Bitcoin culture."},
    {"type":"richtext","id":"editorial_copy","label":"Editorial copy","default":"<p>Use these configurable cards for future essays, interviews, explainers, and field notes.</p>"},
    {"type":"text","id":"discovery_kicker","label":"Discovery kicker","default":"Discovery Grid"},
    {"type":"text","id":"discovery_heading","label":"Discovery heading","default":"People, companies, and projects to index next."},
    {"type":"richtext","id":"discovery_copy","label":"Discovery copy","default":"<p>Profiles are placeholders until real first-party directory content is published.</p>"},
    {"type":"text","id":"reports_kicker","label":"Reports kicker","default":"Monthly On-Chain Reports"},
    {"type":"text","id":"reports_heading","label":"Reports heading","default":"Research previews without invented live data."},
    {"type":"richtext","id":"reports_copy","label":"Reports copy","default":"<p>Future reports can summarize fees, inscriptions, miner behavior, liquidity, and ecosystem activity once verified sources are connected.</p>"},
    {"type":"text","id":"recent_kicker","label":"Recent kicker","default":"Recently Added"},
    {"type":"text","id":"recent_heading","label":"Recent heading","default":"Latest index activity."}
  ],
  "blocks": [
    {"type":"category","name":"Category","settings":[{"type":"text","id":"meta","label":"Meta","default":"Index"},{"type":"text","id":"title","label":"Title","default":"Artists"},{"type":"textarea","id":"description","label":"Description","default":"Browse creative work and cultural signals."},{"type":"url","id":"link","label":"Link"}]},
    {"type":"editorial","name":"Editorial card","settings":[{"type":"select","id":"size","label":"Card size","options":[{"value":"lead","label":"Lead"},{"value":"standard","label":"Standard"}],"default":"standard"},{"type":"text","id":"label","label":"Label","default":"Field Note"},{"type":"text","id":"title","label":"Title","default":"A placeholder guide to Bitcoin culture"},{"type":"textarea","id":"dek","label":"Description","default":"Replace this with a real MSC editorial summary when published."},{"type":"text","id":"meta","label":"Meta","default":"Draft placeholder"},{"type":"url","id":"link","label":"Link"}]},
    {"type":"profile","name":"Profile card","settings":[{"type":"text","id":"tag","label":"Tag","default":"Artist"},{"type":"text","id":"title","label":"Title","default":"Profile placeholder"},{"type":"text","id":"role","label":"Role","default":"Directory entry pending"},{"type":"textarea","id":"description","label":"Description","default":"A configurable card reserved for a verified future profile."},{"type":"url","id":"link","label":"Link"}]},
    {"type":"report","name":"Report preview","settings":[{"type":"text","id":"month","label":"Month","default":"Upcoming"},{"type":"text","id":"title","label":"Title","default":"Monthly on-chain report template"},{"type":"text","id":"status","label":"Status","default":"Data source pending"},{"type":"url","id":"link","label":"Link"}]},
    {"type":"recent","name":"Recent activity","settings":[{"type":"text","id":"title","label":"Title","default":"Explore redesign installed"},{"type":"text","id":"note","label":"Note","default":"First-party MSC section ready for content"}]}
  ],
  "presets": [{"name":"MSC Explore"}]
}
{% endschema %}
