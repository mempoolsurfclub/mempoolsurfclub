      "label": "Breaking News front-page hours",
      "min": 12,
      "max": 96,
      "step": 12,
      "default": 48
    },
    {
      "type": "text",
      "id": "editorial_kicker",
      "label": "Editorial kicker",
      "default": "Signals From the Culture"
    },
    {
      "type": "text",
      "id": "editorial_heading",
