      "label": "Explore content blog"
    },
    {
      "type": "paragraph",
      "content": "Select one editorial blog. Give every article one primary category tag, then add secondary routing tags. Newest qualifying articles appear first. Breaking News leaves front-facing feeds after the configured window but remains published."
    },
    {
      "type": "text",
      "id": "interviews_tag",
      "label": "Interviews tag",
      "default": "Interviews"
    },
    {
      "type": "text",
      "id": "highlights_tag",
      "label": "Highlights tag",
      "default": "Highlights"
    },
    {
      "type": "text",
      "id": "weekly_recaps_tag",
      "label": "Weekly Recaps tag",
      "default": "Weekly Recaps"
    },
    {
      "type": "text",
      "id": "community_tag",
      "label": "Community tag",
      "default": "Community"
    },
    {
      "type": "text",
      "id": "breaking_news_tag",
      "label": "Breaking News tag",
      "default": "Breaking News"
    },
    {
      "type": "textarea",
      "id": "culture_index_tags",
      "label": "Culture Index routing tags",
      "default": "Artist, Founder, Builder, Miner, Content Creator, Company, Project"
    },
    {
