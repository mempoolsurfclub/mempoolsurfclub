    {
      "type": "text",
      "id": "signal_phrase_2",
      "label": "Signal phrase 2",
      "default": "READING NETWORK + CULTURE SIGNALS"
    },
    {
      "type": "text",
      "id": "signal_phrase_3",
      "label": "Signal phrase 3",
      "default": "WATCHING THE MEMPOOL"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "EXPLORE THE ECOSYSTEM."
    },
    {
      "type": "richtext",
      "id": "supporting_copy",
      "label": "Supporting copy",
      "default": "<p>Bitcoin moves in waves through art, code, people, projects, and ideas. Explore the cultural signals shaping the same ocean.</p>"
    },
    {
      "type": "text",
      "id": "search_label",
      "label": "Search accessible label",
      "default": "Search the Bitcoin culture index"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search artists, founders, companies, projects, reports..."
    },
    {
      "type": "text",
      "id": "search_button",
      "label": "Search button",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "search_types",
      "label": "Shopify search types",
      "default": "article,page,product"
    },
    {
      "type": "url",
      "id": "map_companies_link",
      "label": "Companies page"
