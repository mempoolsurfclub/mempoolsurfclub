{{ 'mempool-ui.css' | asset_url | stylesheet_tag }}

{%- assign search_input_id = 'MscExploreSearchInput-' | append: section.id -%}

<section class="msc-shell msc-explore" id="MscExplore-{{ section.id }}">
  <div class="msc-container">
    <div class="msc-explore-hero">
      <div class="msc-explore-hero__content">
        <p class="msc-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        <h1 class="msc-title msc-explore-hero__title">{{ section.settings.heading | escape }}</h1>
        <div class="msc-subtitle msc-explore-hero__copy rte">{{ section.settings.supporting_copy }}</div>
        {% render 'msc-search-form', input_id: search_input_id, placeholder: section.settings.search_placeholder, button_label: section.settings.search_button, search_types: section.settings.search_types, label: section.settings.search_label, modifier: 'explore' %}
      </div>
      <div class="msc-discovery-map msc-glass-card" aria-label="Cultural wave map visual">
        <div class="msc-discovery-map__header"><span>Cultural Wave Map</span><span>Current Index</span></div>
        <div class="msc-discovery-map__field" aria-hidden="true">
          <svg class="msc-discovery-map__chart" viewBox="0 0 720 420" preserveAspectRatio="none" focusable="false" aria-hidden="true">
            <path class="msc-discovery-map__wave msc-discovery-map__wave--macro" d="M 24 244 C 110 118 208 118 294 244 S 478 370 568 244 S 662 145 696 176" />
            <path class="msc-discovery-map__wave msc-discovery-map__wave--ripple" d="M 20 166 C 52 126 84 126 116 166 S 180 206 212 166 S 276 126 308 166 S 372 206 404 166 S 468 126 500 166 S 564 206 596 166 S 660 126 700 166" />
            <path class="msc-discovery-map__wave msc-discovery-map__wave--current" d="M 28 306 C 116 274 154 214 224 226 C 316 242 332 326 424 300 C 504 278 532 202 610 214 C 648 220 674 244 700 268" />
          </svg>
          <span class="msc-discovery-map__node msc-discovery-map__node--a"><i></i>Art</span>
          <span class="msc-discovery-map__node msc-discovery-map__node--b"><i></i>Builders</span>
          <span class="msc-discovery-map__node msc-discovery-map__node--c"><i></i>Research</span>
          <span class="msc-discovery-map__node msc-discovery-map__node--d"><i></i>Projects</span>
        </div>
        <div class="msc-discovery-map__legend" aria-hidden="true">
          <span><i></i>Macro Swell</span>
          <span><i></i>Technical Ripple</span>
          <span><i></i>Cultural Current</span>
        </div>
        <p>{{ section.settings.visual_caption | escape }}</p>
      </div>
    </div>

    <nav class="msc-explore-categories" aria-label="Explore categories">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          {% render 'msc-category-card', title: block.settings.title, description: block.settings.description, link: block.settings.link, meta: block.settings.meta %}
        {%- endif -%}
      {%- endfor -%}
    </nav>

    <div class="msc-block" aria-labelledby="MscExploreEditorials-{{ section.id }}">
      {% render 'msc-section-header', kicker: section.settings.editorial_kicker, heading: section.settings.editorial_heading, copy: section.settings.editorial_copy, heading_id: 'MscExploreEditorials-' | append: section.id %}
      <div class="msc-editorial-layout">
        {%- for block in section.blocks -%}
          {%- if block.type == 'editorial' -%}
            {% render 'msc-editorial-card', title: block.settings.title, dek: block.settings.dek, label: block.settings.label, link: block.settings.link, meta: block.settings.meta, size: block.settings.size %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="msc-block" aria-labelledby="MscExploreDiscovery-{{ section.id }}">
      {% render 'msc-section-header', kicker: section.settings.discovery_kicker, heading: section.settings.discovery_heading, copy: section.settings.discovery_copy, heading_id: 'MscExploreDiscovery-' | append: section.id %}
      <div class="msc-profile-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'profile' -%}
            {% render 'msc-profile-card', title: block.settings.title, role: block.settings.role, description: block.settings.description, link: block.settings.link, tag: block.settings.tag %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="msc-block" aria-labelledby="MscExploreReports-{{ section.id }}">
      <div class="msc-report-panel msc-glass-card">
        {% render 'msc-section-header', kicker: section.settings.reports_kicker, heading: section.settings.reports_heading, copy: section.settings.reports_copy, heading_id: 'MscExploreReports-' | append: section.id %}
        <div class="msc-report-panel__list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'report' -%}
              <a class="msc-report-row" href="{{ block.settings.link | default: '#MainContent' }}"><span>{{ block.settings.month | escape }}</span><strong>{{ block.settings.title | escape }}</strong><em>{{ block.settings.status | escape }}</em></a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>

    <div class="msc-block" aria-labelledby="MscExploreRecent-{{ section.id }}">
      {% render 'msc-section-header', kicker: section.settings.recent_kicker, heading: section.settings.recent_heading, heading_id: 'MscExploreRecent-' | append: section.id %}
      <div class="msc-update-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'recent' -%}
            <div class="msc-update-row msc-glass-card"><strong>{{ block.settings.title | escape }}</strong><span>{{ block.settings.note | escape }}</span></div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MSC Explore",
  "tag": "section",
  "class": "section",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"BITCOIN CULTURE INDEX"},
    {"type":"text","id":"heading","label":"Heading","default":"EXPLORE THE ECOSYSTEM."},
    {"type":"richtext","id":"supporting_copy","label":"Supporting copy","default":"<p>Bitcoin moves in waves—through art, code, people, projects, and ideas. Explore the cultural signals shaping the same ocean.</p>"},
    {"type":"text","id":"search_label","label":"Search accessible label","default":"Search the Bitcoin culture index"},
    {"type":"text","id":"search_placeholder","label":"Search placeholder","default":"Search artists, founders, companies, projects, reports..."},
    {"type":"text","id":"search_button","label":"Search button","default":"Search"},
    {"type":"text","id":"search_types","label":"Shopify search types","default":"article,page,product"},
    {"type":"text","id":"visual_caption","label":"Visual caption","default":"An abstract atlas of macro swell, technical ripples, and cultural currents moving through Bitcoin."},
    {"type":"text","id":"editorial_kicker","label":"Editorial kicker","default":"Signals From the Culture"},
    {"type":"text","id":"editorial_heading","label":"Editorial heading","default":"Stories moving through the Bitcoin ocean."},
    {"type":"richtext","id":"editorial_copy","label":"Editorial copy","default":"<p>Upcoming MSC essays, interviews, explainers, and field notes will chart the ideas gathering momentum across Bitcoin culture.</p>"},
    {"type":"text","id":"discovery_kicker","label":"Discovery kicker","default":"People Behind the Current"},
    {"type":"text","id":"discovery_heading","label":"Discovery heading","default":"Artists, builders, companies, and projects shaping the next wave."},
    {"type":"richtext","id":"discovery_copy","label":"Discovery copy","default":"<p>Upcoming MSC profiles will collect verified context on the people, companies, and projects shaping Bitcoin culture.</p>"},
    {"type":"text","id":"reports_kicker","label":"Reports kicker","default":"On-Chain Swell Report"},
    {"type":"text","id":"reports_heading","label":"Reports heading","default":"Monthly readings from the network."},
    {"type":"richtext","id":"reports_copy","label":"Reports copy","default":"<p>Upcoming MSC reports will turn verified network observations into clear monthly context without inventing live data.</p>"},
    {"type":"text","id":"recent_kicker","label":"Recent kicker","default":"New Signals"},
    {"type":"text","id":"recent_heading","label":"Recent heading","default":"Recently added to the index."}
  ],
  "blocks": [
    {"type":"category","name":"Category","settings":[{"type":"text","id":"meta","label":"Meta","default":"Index"},{"type":"text","id":"title","label":"Title","default":"Artists"},{"type":"textarea","id":"description","label":"Description","default":"Browse creative work and cultural signals."},{"type":"url","id":"link","label":"Link"}]},
    {"type":"editorial","name":"Editorial card","settings":[{"type":"select","id":"size","label":"Card size","options":[{"value":"lead","label":"Lead"},{"value":"standard","label":"Standard"}],"default":"standard"},{"type":"text","id":"label","label":"Label","default":"Field Note"},{"type":"text","id":"title","label":"Title","default":"A field guide to Bitcoin culture"},{"type":"textarea","id":"dek","label":"Description","default":"Reserved for upcoming MSC coverage of the people, projects, and ideas moving through Bitcoin."},{"type":"text","id":"meta","label":"Meta","default":"Upcoming coverage"},{"type":"url","id":"link","label":"Link"}]},
    {"type":"profile","name":"Profile card","settings":[{"type":"text","id":"tag","label":"Tag","default":"Artist"},{"type":"text","id":"title","label":"Title","default":"Profile signal"},{"type":"text","id":"role","label":"Role","default":"Coverage queued"},{"type":"textarea","id":"description","label":"Description","default":"Reserved for verified MSC context on a future culture index subject."},{"type":"url","id":"link","label":"Link"}]},
    {"type":"report","name":"Report preview","settings":[{"type":"text","id":"month","label":"Month","default":"Upcoming"},{"type":"text","id":"title","label":"Title","default":"Monthly on-chain swell report"},{"type":"text","id":"status","label":"Status","default":"Verified sources queued"},{"type":"url","id":"link","label":"Link"}]},
    {"type":"recent","name":"Recent activity","settings":[{"type":"text","id":"title","label":"Title","default":"Cultural wave map added"},{"type":"text","id":"note","label":"Note","default":"Explore now frames culture as signals moving through Bitcoin."}]}
  ],
  "presets": [{"name":"MSC Explore"}]
}
{% endschema %}
