{{ 'mempool-ui.css' | asset_url | stylesheet_tag }}
{%- capture learn_path_data -%}{%- render 'msc-learn-path-data' -%}{%- endcapture -%}{%- capture learn_guide_data -%}{%- render 'msc-learn-guide-data' -%}{%- endcapture -%}{%- assign newline_delimiter = '
' -%}{%- assign path_rows = learn_path_data | strip | split: newline_delimiter -%}{%- assign guide_rows = learn_guide_data | strip | split: newline_delimiter -%}{%- assign current = '' -%}{%- for row in path_rows -%}{%- assign item = row | split: '[[MSC_FIELD]]' -%}{%- if item[1] == page.handle -%}{%- assign current = item -%}{%- endif -%}{%- endfor -%}{%- assign learn_page = pages['learn'] -%}
<section class="msc-shell msc-learn-page"><div class="msc-container msc-learn-page__container">
{% render 'msc-learn-breadcrumbs', learn_page: learn_page, current_label: page.title %}<header class="msc-learn-page__header"><p class="msc-section-kicker">Learning Path</p><h1>{{ page.title | escape }}</h1>{% render 'msc-learn-page-meta', page: page, depth: current[5] %}<div class="msc-learn-article rte">{{ page.content }}</div></header>
<ol class="msc-learn-route-list">{%- assign ids = current[3] | split: '[[MSC_LIST]]' -%}{%- for id in ids -%}{%- for row in guide_rows -%}{%- assign g = row | split: '[[MSC_FIELD]]' -%}{%- if g[0] == id -%}{%- assign guide_page = pages[g[1]] -%}{%- if guide_page -%}<li><a class="msc-learn-guide-card msc-glass-card" href="{{ guide_page.url }}"><strong>{{ guide_page.title | escape }}</strong><span>{{ g[4] | escape }}</span></a></li>{%- endif -%}{%- endif -%}{%- endfor -%}{%- if id == 'MSC-ROUTE-001' -%}{%- assign route_page = pages['how-a-bitcoin-transaction-moves'] -%}{%- if route_page -%}<li><a class="msc-learn-guide-card msc-glass-card" href="{{ route_page.url }}"><strong>{{ route_page.title | escape }}</strong><span>Featured Route</span></a></li>{%- endif -%}{%- endif -%}{%- endfor -%}</ol>
{% render 'msc-learn-prev-next', parent_handle: 'learn', parent_label: 'Learn', learn_page: learn_page %}
</div></section>
{% schema %}{"name":"MSC Learn path","settings":[]}{% endschema %}
