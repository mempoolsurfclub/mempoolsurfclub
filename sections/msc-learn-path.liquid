{{ 'mempool-ui.css' | asset_url | stylesheet_tag }}
{%- assign path_rows = render 'msc-learn-path-data' | strip | split: '\n' -%}{%- assign guide_rows = render 'msc-learn-guide-data' | strip | split: '\n' -%}{%- assign current = '' -%}{%- for row in path_rows -%}{%- assign item = row | split: '|' -%}{%- if item[1] == page.handle -%}{%- assign current = item -%}{%- endif -%}{%- endfor -%}{%- assign learn_page = pages['learn'] -%}
<section class="msc-shell msc-learn-page"><div class="msc-container msc-learn-page__container">
{% render 'msc-learn-breadcrumbs', learn_page: learn_page, current_label: page.title %}<header class="msc-learn-page__header"><p class="msc-section-kicker">Learning Path</p><h1>{{ page.title | escape }}</h1>{% render 'msc-learn-page-meta', page: page, depth: current[5] %}<div class="msc-learn-article rte">{{ page.content }}</div></header>
<ol class="msc-learn-route-list">{%- assign ids = current[3] | split: ',' -%}{%- for id in ids -%}{%- for row in guide_rows -%}{%- assign g = row | split: '|' -%}{%- if g[0] == id -%}{%- assign guide_page = pages[g[1]] -%}{%- if guide_page -%}<li><a class="msc-learn-guide-card msc-glass-card" href="{{ guide_page.url }}"><strong>{{ guide_page.title | escape }}</strong><span>{{ g[4] | escape }}</span></a></li>{%- endif -%}{%- endif -%}{%- endfor -%}{%- endfor -%}</ol>
{% render 'msc-learn-prev-next', parent_handle: 'learn', parent_label: 'Learn', learn_page: learn_page %}
</div></section>
{% schema %}{"name":"MSC Learn path","settings":[]}{% endschema %}
