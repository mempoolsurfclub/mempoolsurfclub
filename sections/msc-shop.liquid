{{ 'mempool-ui.css' | asset_url | stylesheet_tag }}

<section class="msc-shell msc-shop" id="MscShop-{{ section.id }}">
  <div class="msc-container">
    <div class="msc-shop-hero">
      <div class="msc-shop-hero__content">
        <p class="msc-eyebrow">{{ section.settings.hero_eyebrow | escape }}</p>
        <h1 class="msc-title">{{ section.settings.hero_heading | escape }}</h1>
        <div class="msc-subtitle rte">{{ section.settings.hero_copy }}</div>
        <div class="msc-shop-actions">
          {%- if section.settings.primary_label != blank -%}<a class="msc-button" href="{{ section.settings.primary_link | default: routes.collections_url }}">{{ section.settings.primary_label | escape }}</a>{%- endif -%}
          {%- if section.settings.secondary_label != blank -%}<a class="msc-button msc-button--ghost" href="{{ section.settings.secondary_link | default: routes.collections_url }}">{{ section.settings.secondary_label | escape }}</a>{%- endif -%}
        </div>
      </div>
      <div class="msc-manifest msc-glass-card" aria-label="Collection manifest">
        <div class="msc-manifest__top"><span>CORE COLLECTION</span><span>MSC / 001</span></div>
        <div class="msc-manifest__label"><span>FIELD ISSUE</span><strong>BUILT FOR THE LONG WAVE</strong></div>
        <div class="msc-manifest__grid" aria-hidden="true"><span>HEADWEAR</span><span>TEES</span><span>FLEECE</span><span>OBJECTS</span></div>
        <div class="msc-manifest__ticks" aria-hidden="true"></div>
      </div>
    </div>

    <div class="msc-block">
      {% render 'msc-section-header', kicker: section.settings.category_kicker, heading: section.settings.category_heading, copy: section.settings.category_copy, heading_id: 'MscShopCategories-' | append: section.id %}
      <div class="msc-collection-grid" aria-labelledby="MscShopCategories-{{ section.id }}">
        {%- for block in section.blocks -%}{%- if block.type == 'category' -%}
          {% render 'msc-collection-card', collection: block.settings.collection, title: block.settings.title, description: block.settings.description, image: block.settings.image, issue: block.settings.issue, link: block.settings.link %}
        {%- endif -%}{%- endfor -%}
      </div>
    </div>

    <div class="msc-block">
      {% render 'msc-section-header', kicker: section.settings.current_kicker, heading: section.settings.current_heading, copy: section.settings.current_copy, heading_id: 'MscShopCurrent-' | append: section.id %}
      <div class="msc-collection-grid msc-collection-grid--current" aria-labelledby="MscShopCurrent-{{ section.id }}">
        {%- for block in section.blocks -%}{%- if block.type == 'current_collection' -%}
          {% render 'msc-collection-card', collection: block.settings.collection, title: block.settings.title, collection_type: block.settings.collection_type, credit: block.settings.credit, description: block.settings.description, image: block.settings.image, issue: block.settings.issue, editorial_link: block.settings.editorial_link %}
        {%- endif -%}{%- endfor -%}
      </div>
    </div>

    <div class="msc-block msc-shop-products">
      {% render 'msc-section-header', kicker: section.settings.featured_kicker, heading: section.settings.featured_heading, heading_id: 'MscShopFeatured-' | append: section.id %}
      {%- if section.settings.featured_collection != blank and section.settings.featured_collection.products_count > 0 -%}
        <div class="msc-product-grid" aria-labelledby="MscShopFeatured-{{ section.id }}">
          {%- for product in section.settings.featured_collection.products limit: 4 -%}
            {% render 'card-product', card_product: product, media_aspect_ratio: 'adapt', show_secondary_image: false, show_vendor: section.settings.show_vendor, show_rating: false, lazy_load: true, section_id: section.id, quick_add: 'none' %}
          {%- endfor -%}
        </div>
      {%- else -%}
        <div class="msc-empty-state msc-glass-card">Core collection being assembled.</div>
      {%- endif -%}
    </div>

    <div class="msc-block msc-notes">
      {% render 'msc-section-header', kicker: section.settings.notes_kicker, heading: section.settings.notes_heading, heading_id: 'MscShopNotes-' | append: section.id %}
      <div class="msc-note-grid">
        {%- for block in section.blocks -%}{%- if block.type == 'note' -%}<article class="msc-note msc-glass-card"><span>{{ block.settings.index | escape }}</span><h3>{{ block.settings.title | escape }}</h3><p>{{ block.settings.description | escape }}</p></article>{%- endif -%}{%- endfor -%}
      </div>
    </div>

    <div class="msc-block msc-collab-panel msc-glass-card">
      <div class="msc-collab-panel__media">{%- if section.settings.collab_image != blank -%}{{ section.settings.collab_image | image_url: width: 1000 | image_tag: loading: 'lazy', widths: '400, 700, 1000', sizes: '(min-width: 990px) 42vw, 92vw', alt: section.settings.collab_heading }}{%- else -%}<div class="msc-pattern-fallback" aria-hidden="true"><span></span><span></span><span></span></div>{%- endif -%}</div>
      <div><p class="msc-section-kicker">{{ section.settings.collab_kicker | escape }}</p><h2 class="msc-section-title">{{ section.settings.collab_heading | escape }}</h2><div class="rte">{{ section.settings.collab_copy }}</div>{%- if section.settings.collab_button_label != blank -%}<a class="msc-button" href="{{ section.settings.collab_link | default: routes.collections_url }}">{{ section.settings.collab_button_label | escape }}</a>{%- endif -%}</div>
    </div>
  </div>
</section>

