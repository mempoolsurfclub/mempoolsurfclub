{{ 'mempool-ui.css' | asset_url | stylesheet_tag }}

<section class="msc-shell msc-collection-hero" id="MscCollectionHero-{{ section.id }}">
  <div class="msc-container">
    <div class="msc-collection-hero__layout">
      <div class="msc-collection-hero__content">
        <p class="msc-eyebrow">{{ section.settings.catalog_label | escape }}</p>
        <h1 class="msc-title">{{ collection.title | escape }}</h1>
        {%- if collection.description != blank -%}<div class="msc-subtitle rte">{{ collection.description }}</div>{%- endif -%}
        <p class="msc-collection-count">{{ collection.products_count }} {{ collection.products_count | pluralize: 'object', 'objects' }} cataloged</p>
      </div>
      <div class="msc-collection-hero__image msc-glass-card">
        {%- if collection.featured_image != blank -%}
          {{ collection.featured_image | image_url: width: 1200 | image_tag: loading: 'eager', widths: '500, 800, 1200', sizes: '(min-width: 990px) 42vw, 92vw', alt: collection.title }}
        {%- else -%}
          <div class="msc-pattern-fallback" aria-hidden="true"><span></span><span></span><span></span></div>
        {%- endif -%}
        <div class="msc-collection-hero__stamp" aria-hidden="true"><span>FIELD ISSUE</span><strong>{{ collection.handle | upcase }}</strong></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{"name":"MSC collection hero","tag":"section","class":"section","settings":[{"type":"text","id":"catalog_label","label":"Catalog label","default":"MSC PRODUCT ARCHIVE"}]}
{% endschema %}
