    {"type":"why_principle","settings":{"marker":"01","title":"Bitcoin First","description":"Every part of MSC begins with Bitcoin—not a broader crypto category."}},{"type":"why_principle","settings":{"marker":"02","title":"Watch the Network","description":"The mempool, miners, nodes, builders, and protocols reveal how the system is moving."}},{"type":"why_principle","settings":{"marker":"03","title":"Document the Culture","description":"Artists, founders, companies, communities, and ideas shape the world growing around the protocol."}},{"type":"why_principle","settings":{"marker":"04","title":"Carry It Forward","description":"Editorials, education, tools, gatherings, and physical objects help the culture move beyond the screen."}},
    {"type":"platform_item","settings":{"entry":"LOG 01","title":"Explore","description":"Profiles, editorials, projects, reports, and cultural signals.","link":"shopify://pages/explore"}},{"type":"platform_item","settings":{"entry":"LOG 02","title":"Learn","description":"Clear routes through Bitcoin fundamentals and the wider ecosystem.","link":"shopify://pages/learn"}},{"type":"platform_item","settings":{"entry":"LOG 03","title":"Tools","description":"Interfaces for reading network conditions and making informed decisions.","link":"shopify://pages/tools"}},{"type":"platform_item","settings":{"entry":"LOG 04","title":"Shop","description":"MSC releases and independent collections from artists and projects.","link":"shopify://pages/shop"}},{"type":"platform_item","settings":{"entry":"LOG 05","title":"Community","description":"Meetups, conversations, collaborations, and shared observation."}},
    {"type":"club_principle","settings":{"title":"Stay Curious","description":"Keep asking better questions before declaring the wave understood."}},{"type":"club_principle","settings":{"title":"Think Long Term","description":"Favor durable signal over short-lived noise."}},{"type":"club_principle","settings":{"title":"Respect Natural Systems","description":"Observe incentives, cycles, limits, and emergent order with patience."}},{"type":"club_principle","settings":{"title":"Choose Independence","description":"Keep editorial judgment and cultural direction clear."}},{"type":"club_principle","settings":{"title":"Make With Purpose","description":"Build objects, guides, and tools that earn their place."}},{"type":"club_principle","settings":{"title":"Keep Watching","description":"Return to the network and the people moving through it."}},
    {"type":"community_action","settings":{"label":"Meetups"}},{"type":"community_action","settings":{"label":"Collaborate"}},{"type":"community_action","settings":{"label":"Submit a project"}},{"type":"community_action","settings":{"label":"Follow MSC"}},
    {"type":"log_entry","settings":{"entry":"ENTRY 001","title":"Brand system established","note":"The shared MSC visual language is in place for the first clubhouse foundation."}},{"type":"log_entry","settings":{"entry":"ENTRY 002","title":"Platform structure mapped","note":"Explore, Learn, Tools, Shop, and Community now sit inside one About framework."}},{"type":"log_entry","settings":{"entry":"ENTRY 003","title":"First field reports in development","note":"Space is reserved for future verified reports and observations."}},{"type":"log_entry","settings":{"entry":"ENTRY 004","title":"Core collection being assembled","note":"The archive can grow as real projects and releases are ready."}}
  ]}]
