    {"type":"text","id":"support_kicker","label":"Support kicker","default":"SUPPORT THE CLUB"},{"type":"text","id":"support_heading","label":"Support heading","default":"Help keep the signal independent."},{"type":"richtext","id":"support_copy","label":"Support copy","default":"<p>Support can help fund independent editorials, educational resources, tools, gatherings, and future cultural projects.</p>"},{"type":"textarea","id":"bitcoin_address","label":"Bitcoin wallet address"},{"type":"text","id":"lightning_address","label":"Lightning address"},{"type":"textarea","id":"support_explanation","label":"Support explanation"},{"type":"image_picker","id":"qr_image","label":"QR-code image"},{"type":"text","id":"qr_image_alt","label":"QR-code image alt text","default":"Support QR code"},{"type":"text","id":"support_button_label","label":"Support button label","default":"Support MSC"},{"type":"url","id":"support_button_link","label":"Support button link"},
    {"type":"checkbox","id":"show_log","label":"Show club log","default":true},{"type":"text","id":"log_kicker","label":"Log kicker","default":"CLUB LOG"},{"type":"text","id":"log_heading","label":"Log heading","default":"Notes from the archive."},
    {"type":"text","id":"final_heading","label":"Final heading","default":"THE OCEAN IS ALWAYS MOVING."},{"type":"richtext","id":"final_copy","label":"Final copy","default":"<p>Keep watching the network, the culture, and the ideas forming beneath the surface.</p>"},{"type":"text","id":"final_primary_label","label":"Final primary label","default":"Explore MSC"},{"type":"url","id":"final_primary_link","label":"Final primary link"},{"type":"text","id":"final_secondary_label","label":"Final secondary label","default":"Open Network Tools"},{"type":"url","id":"final_secondary_link","label":"Final secondary link"}
  ],
  "blocks": [
