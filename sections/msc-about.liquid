    {"type":"platform_item","name":"Platform item","settings":[{"type":"text","id":"entry","label":"Log number","default":"LOG 01"},{"type":"text","id":"marker","label":"Marker","default":"◌"},{"type":"text","id":"title","label":"Title","default":"Explore"},{"type":"textarea","id":"description","label":"Description","default":"Profiles, editorials, projects, reports, and cultural signals."},{"type":"url","id":"link","label":"Link"}]},
    {"type":"club_principle","name":"Club principle","settings":[{"type":"text","id":"marker","label":"Marker","default":"•"},{"type":"text","id":"title","label":"Title","default":"Stay Curious"},{"type":"textarea","id":"description","label":"Description","default":"Keep asking better questions before declaring the wave understood."}]},
    {"type":"community_action","name":"Community action","settings":[{"type":"text","id":"label","label":"Label","default":"Meetups"},{"type":"url","id":"link","label":"Link"}]},
    {"type":"log_entry","name":"Log entry","settings":[{"type":"text","id":"entry","label":"Entry number","default":"ENTRY 001"},{"type":"text","id":"title","label":"Title","default":"Brand system established"},{"type":"textarea","id":"note","label":"Note","default":"The shared MSC visual language is in place for the first clubhouse foundation."},{"type":"text","id":"date","label":"Optional date"},{"type":"url","id":"link","label":"Optional link"}]}
